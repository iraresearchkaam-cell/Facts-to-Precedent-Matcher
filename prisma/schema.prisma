datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  extensions = [vector]
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

model PrecedentCase {
  id              String   @id @default(uuid())
  citation        String   @unique
  caseName        String
  fullJudgment    String   @db.Text
  factSummary     String   @db.Text
  winningArgument String   @db.Text

  factEmbedding   String?   @db.Text

  createdAt       DateTime @default(now())
}

model UserSearch {
  id             String   @id @default(uuid())
  userId         String
  rawInput       String   @db.Text
  extractedFacts Json

  comparisonMemo String   @db.Text

  createdAt      DateTime @default(now())
}
